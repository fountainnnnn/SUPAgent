# ── Platform / demo credentials (you provide these) ──
# Gmail account used to send real replies in the demo.
# Use an app password (not the account password); IMAP/SMTP must be enabled.
GMAIL_USER=your-hackathon-account@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Comma-separated allow-list of recipients the agent is permitted to email.
# /api/send REJECTS any recipient not on this list (code-level guardrail).
ALLOWED_RECIPIENTS=you@example.com

# Code-level action cap: refunds at/above this require human approval.
REFUND_CAP=100

# Server port (client proxies /api here).
PORT=8787

# ── Phase 2 only (not needed for the demo) ──
# OPENAI_API_KEY=
# EXA_API_KEY=
